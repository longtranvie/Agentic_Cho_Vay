# Sao chép thành .env và điền giá trị thật. KHÔNG commit .env.
# ⚠️ KHÔNG dán key thật vào FILE NÀY (.env.example được commit lên git). Dán vào .env.

# Chọn provider LLM: mock (chạy offline, không cần key) | openai
LOAN_LLM_PROVIDER=mock

# --- OpenAI (ADR-0006) — chỉ cần khi LOAN_LLM_PROVIDER=openai ---
OPENAI_API_KEY=sk-...
LOAN_LLM_MODEL=gpt-4o-mini
LOAN_LLM_DECISION_MODEL=gpt-4o
LOAN_EMBEDDING_MODEL=text-embedding-3-large

# --- Config / dữ liệu ---
LOAN_DECISION_TABLE=./config/decision_table.json
LOAN_POLICY_DIR=./data/policies

# --- Hội thoại intake (ADR-0003) ---
LOAN_MAX_INTAKE_TURNS=12

# --- TLS sau proxy doanh nghiệp (MITM) ---
# Nếu mạng có proxy chặn TLS, trỏ tới CA root nội bộ (.pem) để gọi OpenAI được:
# LOAN_CA_BUNDLE=C:\path\to\corp-ca.pem
