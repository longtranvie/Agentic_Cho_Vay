# Sao chép thành .env và điền giá trị thật. KHÔNG commit .env.
# ⚠️ KHÔNG dán key thật vào FILE NÀY (.env.example được commit lên git). Dán vào .env.

# Chọn provider LLM: mock (chạy offline, không cần key) | openai
LOAN_LLM_PROVIDER=mock

# --- OpenAI (ADR-0006) — chỉ cần khi LOAN_LLM_PROVIDER=openai ---
OPENAI_API_KEY=sk-...
LOAN_LLM_MODEL=gpt-4o-mini
LOAN_LLM_DECISION_MODEL=gpt-4o
LOAN_EMBEDDING_MODEL=text-embedding-3-large

# --- Config / dữ liệu ---
LOAN_DECISION_TABLE=./config/decision_table.json
LOAN_POLICY_DIR=./data/policies

# --- Hội thoại intake (ADR-0003) ---
LOAN_MAX_INTAKE_TURNS=12

# --- Auth API ---
# Đặt khóa để BẬT xác thực (header X-API-Key). Rỗng = tắt auth — CHỈ dùng khi dev.
# Production BẮT BUỘC đặt khóa bí mật ngẫu nhiên (không dán khóa thật vào file này).
# LOAN_API_KEY=đặt-chuỗi-bí-mật-ngẫu-nhiên

# --- TLS sau proxy doanh nghiệp (MITM) ---
# Nếu mạng có proxy chặn TLS, trỏ CÁC biến CA sau tới cùng 1 file CA root nội bộ (.pem).
# Mỗi thư viện đọc biến khác nhau — thiếu biến nào là phần đó vẫn lỗi SSL:
#   LOAN_CA_BUNDLE     -> client OpenAI (LLM + embeddings) của hệ thống (httpx)
#   SSL_CERT_FILE      -> chromadb / urllib3 (khi RAG = chroma)
#   REQUESTS_CA_BUNDLE -> tiktoken tải bộ mã hóa qua `requests` (khi RAG = chroma)
# Tạo bundle: xuất kho chứng chỉ Windows + gộp certifi (Git đã tin CA này nên push được).
# LOAN_CA_BUNDLE=C:\path\to\corp-ca.pem
# SSL_CERT_FILE=C:\path\to\corp-ca.pem
# REQUESTS_CA_BUNDLE=C:\path\to\corp-ca.pem
